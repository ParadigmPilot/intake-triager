# Phase 8 E2E test environment template.
# Copy to .env.test and fill in. .env.test is gitignored.
#
# DATABASE_URL must point to an isolated test database (NOT the dev DB).
# E2E tests delete owner-scoped rows in afterEach; pointing this at the
# dev DB will destroy local data.

DATABASE_URL=postgresql://localhost:5432/intake_triager_test
ANTHROPIC_API_KEY=
MODEL=claude-sonnet-4-20250514
E2E_TEMPERATURE=0
PORT=0
