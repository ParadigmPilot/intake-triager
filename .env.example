# Anthropic API
ANTHROPIC_API_KEY=

# Database
DATABASE_URL=postgres://user:pass@localhost:5432/intake_triager

# Model
MODEL=claude-sonnet-4-20250514

# Server
PORT=3000

# Rate limiting (per-IP requests per minute on /converse)
RATE_LIMIT_PER_IP_PER_MINUTE=20

# Cost ceiling (cumulative output_tokens per conversation)
CONVERSATION_TOKEN_CEILING=200000

# CORS allowed origins (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Prompt placeholders (substituted into system.md at assembly time)
ORG_NAME=
CRISIS_LINE=
